# DeepWiki-Open Environment Configuration Example

# Application Settings
JWT_SECRET=generate_a_random_string_here
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_another_random_string_here

# Database Configuration
POSTGRES_DB=deepwiki
POSTGRES_PASSWORD=secure_password_here

# AI Model Provider Keys (at least one is required)
GOOGLE_API_KEY=your_google_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Repository Access (optional, for private repos)
# GITHUB_TOKEN=your_personal_access_token_here
